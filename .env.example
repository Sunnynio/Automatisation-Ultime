# ============================================================
# AUTOMATISATION-ULTIME — Variables d'environnement
# ============================================================
# INSTRUCTIONS :
#   1. Copier ce fichier : cp .env.example .env
#   2. Remplir les valeurs réelles dans .env
#   3. NE JAMAIS commiter .env avec de vraies valeurs
# ============================================================

# --- Notion ---
# Obtenir sur https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID du Master Board (déjà rempli — ne pas modifier)
NOTION_DATABASE_ID=afa424a05fe747c58a6606a6e413cda0

# ID du Daily Digest (déjà rempli — ne pas modifier)
NOTION_DIGEST_DATABASE_ID=83292ab853364e7790f4811ef80a9a7f

# IDs des pages Routines (déjà remplis — ne pas modifier)
ROUTINE_MATIN_ID=38fcace54fe1819e8b68f3208b6c7d1c
ROUTINE_AEROPORT_ID=38fcace54fe1819fa390d727895c733e

# --- Google (optionnel — pour intégration Calendar future) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Email (optionnel — pour envoi du Daily Digest par mail) ---
GMAIL_SENDER_EMAIL=

# --- IA externes (optionnel) ---
MISTRAL_API_KEY=

# --- Make.com (optionnel — pour les webhooks d'automatisation) ---
MAKE_API_KEY=
MAKE_WEBHOOK_RESET_MATIN=
MAKE_WEBHOOK_RESET_AEROPORT=

# --- Général ---
TIMEZONE=Asia/Bangkok
DATA_DIR=./data
