# ============================================================
# .env.example — Template des variables d'environnement
# ============================================================
# INSTRUCTIONS :
#   1. Copiez ce fichier en ".env" : cp .env.example .env
#   2. Remplissez vos vraies valeurs dans .env
#   3. NE JAMAIS commiter le fichier .env (il contient des secrets)
# ============================================================

# --- Notion API (OBLIGATOIRE pour les scripts Python) ---

# Token de l'intégration Notion (commence par "secret_")
# Où le créer : https://www.notion.so/my-integrations
# Permissions requises : Lire/écrire les bases de données et pages
NOTION_TOKEN=secret_REMPLACEZ_PAR_VOTRE_TOKEN

# ID du Master Board (base principale des tâches)
# URL Notion : https://app.notion.com/p/0de619a1e693410d94946c4f5fdaf30a
# L'ID = la suite de caractères dans l'URL (sans tirets, sans "?v=...")
NOTION_DATABASE_ID=0de619a1e693410d94946c4f5fdaf30a

# ID de la base Daily Digest (créée le 30/06/2026)
# URL : https://app.notion.com/p/30342149a740489f9cb85b99e82e7486
NOTION_DIGEST_DATABASE_ID=30342149a740489f9cb85b99e82e7486

# --- Paramètres locaux ---

# Fuseau horaire utilisé par les scripts (si ils affichent des dates)
TIMEZONE=Asia/Bangkok

# --- Google API (optionnel — hors scope actuel) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# --- Mistral API (optionnel) ---
# MISTRAL_API_KEY=
